<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Download Sora — macOS browser</title>
  <meta name="description" content="Download Sora for macOS. Free, native, and built with SwiftUI." />
  <style>
/* ── Tokens ─────────────────────────────────────────────── */
:root {
  --bg:       #0b0d12;
  --bg2:      #111318;
  --border:   rgba(255,255,255,0.07);
  --text:     #e8eaf0;
  --muted:    rgba(232,234,240,0.45);
  --accent:   #7b8cff;
  --accent2:  #a78bfa;
  --radius:   14px;
  --shadow:   0 24px 64px rgba(0,0,0,0.5);
  --mono:     'SF Mono','Fira Code','Cascadia Code',monospace;
}

/* ── Reset ──────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--text);
  font: 16px/1.6 -apple-system, system-ui, sans-serif;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* Subtle noise texture */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none;
  opacity: 0.35;
  z-index: 999;
}

a { color: inherit; text-decoration: none; }

/* Focus visible for keyboard nav */
a:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 3px;
  border-radius: 4px;
}

/* ── Layout ─────────────────────────────────────────────── */
.wrap {
  max-width: 1080px;
  margin: 0 auto;
  padding: 0 28px;
}

/* ── Header ─────────────────────────────────────────────── */
header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28px 0;
  opacity: 0;
  animation: fadeUp 0.5s ease forwards;
}

.brand {
  font-size: 18px;
  font-weight: 600;
  letter-spacing: -0.3px;
}

nav {
  display: flex;
  align-items: center;
  gap: 28px;
}

nav a {
  font-size: 14px;
  color: var(--muted);
  transition: color 0.2s;
}
nav a:hover { color: var(--text); }

nav .pill {
  background: rgba(123,140,255,0.12);
  border: 1px solid rgba(123,140,255,0.25);
  color: var(--accent);
  padding: 7px 16px;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 500;
  transition: background 0.2s, border-color 0.2s;
}
nav .pill:hover {
  background: rgba(123,140,255,0.2);
  border-color: rgba(123,140,255,0.4);
  color: var(--accent);
}

/* ── Hero ───────────────────────────────────────────────── */
.hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
  padding: 80px 0 100px;
}

.tag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--mono);
  font-size: 11px;
  color: var(--accent);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: 20px;
  opacity: 0;
  animation: fadeUp 0.5s ease 0.15s forwards;
}
.tag::before {
  content: '';
  width: 20px;
  height: 1px;
  background: var(--accent);
  opacity: 0.6;
}

.heroText h1 {
  font-size: clamp(42px, 5.5vw, 64px);
  font-weight: 700;
  line-height: 1.08;
  letter-spacing: -1.5px;
  margin-bottom: 22px;
  opacity: 0;
  animation: fadeUp 0.55s ease 0.2s forwards;
}

.heroText h1 em {
  font-style: normal;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.sub {
  font-size: 17px;
  color: var(--muted);
  max-width: 420px;
  line-height: 1.65;
  margin-bottom: 36px;
  opacity: 0;
  animation: fadeUp 0.55s ease 0.28s forwards;
}

.cta {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 20px;
  opacity: 0;
  animation: fadeUp 0.55s ease 0.35s forwards;
}

.fine {
  font-size: 11px;
  font-family: var(--mono);
  color: rgba(232,234,240,0.28);
  opacity: 0;
  animation: fadeUp 0.5s ease 0.42s forwards;
}

/* ── Buttons ────────────────────────────────────────────── */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 12px 22px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 500;
  border: 1px solid var(--border);
  transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
  cursor: pointer;
  white-space: nowrap;
}
.btn:hover { transform: translateY(-1px); }
.btn:active { transform: translateY(0); }

.btn.primary {
  background: var(--accent);
  border-color: transparent;
  color: #fff;
  box-shadow: 0 4px 24px rgba(123,140,255,0.3);
}
.btn.primary:hover { box-shadow: 0 8px 32px rgba(123,140,255,0.45); }

.btn.ghost {
  background: transparent;
  color: var(--muted);
}
.btn.ghost:hover {
  color: var(--text);
  border-color: rgba(255,255,255,0.15);
}

.btn.full { width: 100%; }

/* ── Panel (browser mock) ───────────────────────────────── */
.panel {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 18px;
  overflow: hidden;
  box-shadow:
    0 0 0 1px rgba(255,255,255,0.04) inset,
    0 40px 80px rgba(0,0,0,0.5),
    0 0 60px rgba(123,140,255,0.06);
  opacity: 0;
  animation: fadeUp 0.65s ease 0.3s forwards;
  position: relative;
}
.panel::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(123,140,255,0.04) 0%, transparent 60%);
  pointer-events: none;
}

.panelTop {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 18px;
  border-bottom: 1px solid var(--border);
  background: rgba(255,255,255,0.02);
}

.dots {
  display: flex;
  gap: 6px;
}
.dots span {
  width: 10px;
  height: 10px;
  border-radius: 50%;
}
.dots span:nth-child(1) { background: #ff5f57; }
.dots span:nth-child(2) { background: #febc2e; }
.dots span:nth-child(3) { background: #28c840; }

.panelUrlBar {
  flex: 1;
  background: rgba(255,255,255,0.06);
  border: 1px solid var(--border);
  border-radius: 7px;
  padding: 5px 12px;
  font-size: 12px;
  font-family: var(--mono);
  color: var(--muted);
  display: flex;
  align-items: center;
  gap: 6px;
}
.panelUrlBar .lock { font-size: 10px; opacity: 0.5; }

.panelBody {
  padding: 24px 22px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
  border-radius: 10px;
  overflow: hidden;
}

.stat {
  background: var(--bg2);
  padding: 14px 16px;
}
.stat .k {
  font-size: 10px;
  font-family: var(--mono);
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 4px;
}
.stat .v {
  font-size: 18px;
  font-weight: 600;
  letter-spacing: -0.3px;
}

.badges {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  padding: 5px 10px;
  border-radius: 6px;
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border);
  color: var(--muted);
}
.badge .dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--accent);
  opacity: 0.7;
}

/* ── Features ───────────────────────────────────────────── */
#features {
  padding: 80px 0 100px;
}

.featuresHeader {
  margin-bottom: 48px;
}

.eyebrow {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 12px;
}

#features h2 {
  font-size: clamp(30px, 4vw, 44px);
  font-weight: 700;
  letter-spacing: -1px;
  line-height: 1.1;
}
#features h2 span { color: var(--muted); font-weight: 400; }

.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}

.card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 28px;
  transition: border-color 0.2s, transform 0.2s;
  position: relative;
  overflow: hidden;
}
.card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(123,140,255,0.3), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}
.card:hover {
  border-color: rgba(123,140,255,0.2);
  transform: translateY(-2px);
}
.card:hover::before { opacity: 1; }

.cardIcon {
  width: 36px;
  height: 36px;
  border-radius: 9px;
  background: rgba(123,140,255,0.1);
  border: 1px solid rgba(123,140,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  margin-bottom: 18px;
}

.card h3 {
  font-size: 16px;
  font-weight: 600;
  letter-spacing: -0.2px;
  margin-bottom: 8px;
}
.card p {
  font-size: 14px;
  color: var(--muted);
  line-height: 1.6;
}

/* ── Footer ─────────────────────────────────────────────── */
footer {
  border-top: 1px solid var(--border);
  padding: 32px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.copy {
  font-size: 13px;
  font-family: var(--mono);
  color: rgba(232,234,240,0.25);
}

.footerLinks {
  display: flex;
  gap: 24px;
}
.footerLinks a {
  font-size: 13px;
  color: var(--muted);
  transition: color 0.2s;
}
.footerLinks a:hover { color: var(--text); }

/* ── Animations ─────────────────────────────────────────── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── Responsive ─────────────────────────────────────────── */
@media (max-width: 768px) {
  .hero {
    grid-template-columns: 1fr;
    gap: 48px;
    padding: 48px 0 72px;
  }
  .grid { grid-template-columns: 1fr; }
  footer {
    flex-direction: column;
    gap: 16px;
    text-align: center;
  }
}

    /* ── Download page specifics ── */
    .downloadHero {
      padding: 100px 0 80px;
      text-align: center;
      max-width: 560px;
      margin: 0 auto;
    }
    .downloadHero .tag  { justify-content: center; margin-bottom: 24px; }
    .downloadHero h1    { font-size: clamp(36px, 5vw, 56px); letter-spacing: -1.5px; line-height: 1.1; margin-bottom: 18px; }
    .downloadHero .sub  { max-width: 100%; text-align: center; margin-bottom: 40px; }
    .downloadHero .cta  { justify-content: center; margin-bottom: 16px; }
    .downloadHero .fine { text-align: center; }

    .btn.large { padding: 15px 36px; font-size: 16px; border-radius: 13px; }

    .requirements { padding: 0 0 80px; }
    .sectionLabel {
      font-family: var(--mono); font-size: 11px; color: var(--accent);
      text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 24px;
    }
    .reqGrid {
      display: grid; grid-template-columns: repeat(3,1fr);
      gap: 1px; background: var(--border); border-radius: 14px;
      overflow: hidden; border: 1px solid var(--border);
    }
    .reqItem { background: var(--bg2); padding: 22px 24px; }
    .reqItem .k { font-size: 11px; font-family: var(--mono); color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 6px; }
    .reqItem .v { font-size: 15px; font-weight: 600; letter-spacing: -0.2px; }
    .reqItem .v small { font-size: 12px; font-weight: 400; color: var(--muted); display: block; margin-top: 2px; }

    .changelog { padding: 0 0 100px; }
    .changelogHeader { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 24px; }
    .changelogHeader h2 { font-size: 22px; font-weight: 700; letter-spacing: -0.5px; }
    .versionBadge {
      font-family: var(--mono); font-size: 12px; color: var(--accent);
      background: rgba(123,140,255,0.1); border: 1px solid rgba(123,140,255,0.2);
      padding: 4px 10px; border-radius: 6px;
    }
    .release { background: var(--bg2); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; margin-bottom: 12px; }
    .releaseHeader { display: flex; align-items: center; justify-content: space-between; padding: 18px 24px; border-bottom: 1px solid var(--border); }
    .releaseVersion { font-size: 15px; font-weight: 600; letter-spacing: -0.2px; }
    .releaseDate { font-size: 12px; font-family: var(--mono); color: var(--muted); margin-top: 2px; }
    .releaseLatest {
      font-size: 11px; font-family: var(--mono); color: var(--accent);
      background: rgba(123,140,255,0.1); border: 1px solid rgba(123,140,255,0.2);
      padding: 3px 8px; border-radius: 5px;
    }
    .releaseBody { padding: 20px 24px; display: flex; flex-direction: column; gap: 10px; }
    .releaseItem { display: flex; align-items: flex-start; gap: 12px; font-size: 14px; color: var(--muted); line-height: 1.55; }
    .releaseItem::before {
      content: ''; width: 5px; height: 5px; border-radius: 50%;
      background: var(--accent); opacity: 0.5; margin-top: 7px; flex-shrink: 0;
    }
    .releaseItem strong { color: var(--text); font-weight: 500; }

    .downloadHero .tag  { opacity: 0; animation: fadeUp 0.5s ease 0.10s forwards; }
    .downloadHero h1    { opacity: 0; animation: fadeUp 0.55s ease 0.18s forwards; }
    .downloadHero .sub  { opacity: 0; animation: fadeUp 0.55s ease 0.26s forwards; }
    .downloadHero .cta  { opacity: 0; animation: fadeUp 0.55s ease 0.33s forwards; }
    .downloadHero .fine { opacity: 0; animation: fadeUp 0.5s ease 0.40s forwards; }
    .requirements       { opacity: 0; animation: fadeUp 0.55s ease 0.45s forwards; }
    .changelog          { opacity: 0; animation: fadeUp 0.55s ease 0.52s forwards; }

    @media (max-width: 768px) {
      .reqGrid { grid-template-columns: 1fr 1fr; }
      .changelogHeader { flex-direction: column; gap: 12px; }
    }
    @media (max-width: 480px) { .reqGrid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>

  <header class="wrap">
    <a class="brand" href="index.html">Sora</a>
    <nav aria-label="Main navigation">
      <a href="index.html#features">Features</a>
      <a class="pill" href="download.html" aria-current="page">Download</a>
    </nav>
  </header>

  <main>
    <section class="downloadHero wrap">
      <div class="tag" aria-hidden="true">macOS · Free · No account needed</div>
      <h1>Download <em>Sora.</em></h1>
      <p class="sub">Native, fast, and free. A browser built for macOS.</p>
      <div class="cta">
        <a class="btn primary large" href="Sora.dmg" download>↓ &nbsp;Download for macOS</a>
      </div>
      <p class="fine">// Sora.dmg · Universal Binary · macOS 12+</p>
    </section>

    <section class="requirements wrap">
      <p class="sectionLabel">System Requirements</p>
      <div class="reqGrid">
        <div class="reqItem">
          <div class="k">macOS</div>
          <div class="v">Monterey 12+<small>Ventura, Sonoma &amp; Sequoia</small></div>
        </div>
        <div class="reqItem">
          <div class="k">Architecture</div>
          <div class="v">Universal<small>Apple Silicon &amp; Intel</small></div>
        </div>
        <div class="reqItem">
          <div class="k">Size</div>
          <div class="v">~12 MB<small>No Electron, no bloat</small></div>
        </div>
      </div>
    </section>

    <section class="changelog wrap">
      <div class="changelogHeader">
        <h2>Release notes</h2>
        <span class="versionBadge">v1.0 — latest</span>
      </div>
      <div class="release">
        <div class="releaseHeader">
          <div>
            <div class="releaseVersion">Version 1.0</div>
            <div class="releaseDate">March 2026</div>
          </div>
          <span class="releaseLatest">Latest</span>
        </div>
        <div class="releaseBody">
          <div class="releaseItem"><span><strong>Vertical sidebar</strong> — collapsible tab list with a floating pill mode when pinned</span></div>
          <div class="releaseItem"><span><strong>Spotlight address bar</strong> — ⌘L to search with live suggestions from history and Google</span></div>
          <div class="releaseItem"><span><strong>Ad &amp; tracker blocking</strong> — network-level blocking with a live count on the new tab page</span></div>
          <div class="releaseItem"><span><strong>Private windows</strong> — no history, no cookies, gone the moment you close</span></div>
          <div class="releaseItem"><span><strong>Keyboard shortcuts</strong> — ⌘1–9 to jump tabs, ⌘T new tab, ⌘W close</span></div>
          <div class="releaseItem"><span><strong>New tab page</strong> — live clock, time-based greeting, and privacy stats</span></div>
          <div class="releaseItem"><span><strong>Theme engine</strong> — multiple built-in themes with per-theme accent colors</span></div>
        </div>
      </div>
    </section>
  </main>

  <footer class="wrap">
    <p class="copy">© 2026 Sora</p>
    <nav class="footerLinks" aria-label="Footer navigation">
      <a href="index.html">Home</a>
      <a href="privacy.html">Privacy</a>
    </nav>
  </footer>

</body>
</html>
